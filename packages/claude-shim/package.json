{
  "name": "@template/claude-shim",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "description": "SDK-based claude binary replacement for stream-json NDJSON output",
  "bin": {
    "claude-shim": "./dist/bin.js"
  },
