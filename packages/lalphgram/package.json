{
  "name": "@qotaq/lalphgram",
  "version": "0.1.16",
  "type": "module",
  "license": "MIT",
  "description": "Notification service for task tracker and GitHub events",
  "repository": {
    "type": "git",
    "url": "https://github.com/timurrakhimzhan/lalphgram.git",
    "directory": "packages/lalphgram"
  },
  "bin": {
    "lalphgram": "./dist/esm/Main.js"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "scripts": {
    "codegen": "build-utils prepare-v2",
    "build": "pnpm build-esm && pnpm build-annotate && pnpm build-cjs && build-utils pack-v2 && chmod +x dist/dist/esm/Main.js",
    "build-esm": "tsc -b tsconfig.build.json",
    "build-cjs": "babel build/esm --plugins @babel/transform-export-namespace-from --plugins @babel/transform-modules-commonjs --out-dir build/cjs --source-maps",
    "build-annotate": "babel build/esm --plugins annotate-pure-calls --out-dir build/esm --source-maps",
    "check": "tsc -b tsconfig.json",
    "lint": "eslint \"**/{src,test,examples,scripts,dtslint}/**/*.{ts,mjs}\"",
    "lint:fix": "pnpm lint --fix",
    "dev": "LOG_LEVEL=DEBUG tsx src/Main.ts",
    "start": "node build/esm/Main.js",
    "test": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "coverage": "vitest --coverage"
  },
  "dependencies": {
    "@effect/cli": "latest",
    "@effect/experimental": "^0.58.0",
    "@effect/platform": "latest",
    "@effect/platform-node": "latest",
    "@linear/sdk": "latest",
    "@anthropic-ai/claude-agent-sdk": "latest",
    "better-telegraph": "^2.1.1",
    "effect": "latest",
    "octokit": "latest",
    "telegraf": "latest",
    "zod": "latest"
  },
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ]
    }
  }
}
